# Copy this file to ".env" in the project root.
# Get an API key: https://aistudio.google.com/apikey
#
# Gemini is OFF by default (game uses Stub LLM — no API calls).
# Set CHAOS_USE_GEMINI=1 and a valid GOOGLE_API_KEY to use the real API.

CHAOS_USE_GEMINI=0

GOOGLE_API_KEY=

# Optional: same as GOOGLE_API_KEY if you prefer this name
# GEMINI_API_KEY=

# Model name (see Gemini API docs for current ids)
GEMINI_MODEL=gemini-2.0-flash
